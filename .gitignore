# Raw captures can get huge — keep cleaned text + summaries, not raw HTML blobs
sources/html/
sources/transcripts/raw/

# Vector index is rebuildable from the KB
embeddings/*.bin
embeddings/*.faiss
embeddings/*.npy

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/
*.egg-info/
dist/
build/

# Embeddings (large binary — regenerate from KB)
embeddings/chunk_ids.json
# BM25 sparse index (derived artifact, rebuilt alongside the dense index)
embeddings/sparse_index.json

# Index (derived artifact)
indexes/manifest.json
indexes/data-sources.json

# Research-loop scratch: write_atomic stages KB pages here before the atomic
# replace (live/_staging.md), plus any other live/_* scratch the loop drops
# (e.g. live/_loop-13-*). All transient working state, not tracked artifacts.
# The underscore prefix deliberately does NOT match live/.gitkeep (the sole
# tracked file under live/), so the directory still ships in a fresh clone.
live/_*

# Logs
journal/daemon.log
*.log
# ...but test fixtures must ship with the repo so a fresh clone's suite passes.
!tests/fixtures/*.log

# Claude Code harness state — transient council worktrees + local decision ledger
.claude/

# Cross-process lock tokens (copilot/locking.py) — transient runtime state.
*.lock
indexes/index.lock
indexes/seen.json.lock

# OS
Thumbs.db
desktop.ini
